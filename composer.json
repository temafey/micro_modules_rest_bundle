{
    "name": "micro-module/rest-bundle",
    "description": "Reusable REST API infrastructure bundle: API versioning, base controllers, DTO mapping, JSON path filtering, event listeners, CSRF protection, and pagination/HATEOAS traits",
    "type": "symfony-bundle",
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "micro-module/base": "^0.13",
        "psr/log": "^2.0 || ^3.0",
        "symfony/config": "^7.0 || ^8.0",
        "symfony/dependency-injection": "^7.0 || ^8.0",
        "symfony/event-dispatcher": "^7.0 || ^8.0",
        "symfony/framework-bundle": "^7.0 || ^8.0",
        "symfony/http-foundation": "^7.0 || ^8.0",
        "symfony/http-kernel": "^7.0 || ^8.0",
        "symfony/routing": "^7.0 || ^8.0"
    },
    "suggest": {
        "doctrine/dbal": "Required for HealthCheckController database checks",
        "ramsey/uuid": "Required for ProcessUuidListener and UuidToStringTransform",
        "symfony/json-path": "Required for JsonPathFilter component",
        "symfony/object-mapper": "Required for DtoMapper component",
        "symfony/security-csrf": "Required for StatelessCsrfTokenService and CsrfTokenValidationListener"
    },
    "require-dev": {
        "doctrine/dbal": "^4.4",
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-mockery": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^11.0",
        "ramsey/uuid": "^4.0",
        "symfony/json-path": "^7.3 || ^8.0",
        "symfony/object-mapper": "^7.3 || ^8.0",
        "symfony/security-csrf": "^7.0 || ^8.0",
        "symplify/easy-coding-standard": "^12.0"
    },
    "config": {
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "MicroModule\\Rest\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MicroModule\\Rest\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "/home/temafey/php-projects/micro-module/micro_modules_base",
            "options": {
                "versions": {
                    "micro-module/base": "0.13.99"
                }
            }
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
